{
  "name": "sdk-launcher-plugin",
  "version": "0.0.1",
  "description": "Capacitor plugin that launches a native SDK on iOS and Android",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "SdkLauncherPlugin.podspec"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "prepare": "npm run build",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "typescript": "~5.4.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=6.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
